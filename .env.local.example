# Database (AWS RDS MySQL - referral_program)
DATABASE_URL="mysql://username:password@your-rds-host.amazonaws.com:3306/referral_program"

# NextAuth
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# PayPal
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_MODE="sandbox"

# AWS SES
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_SES_FROM_EMAIL="send@referrals.com"

# OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# Integrations
MAILCHIMP_API_KEY=""
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""

# Cron
CRON_SECRET="generate-with: openssl rand -hex 32"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OpenAI (blog auto-generation)
OPENAI_API_KEY=""

# Pexels (blog featured images)
PEXELS_API_KEY=""
